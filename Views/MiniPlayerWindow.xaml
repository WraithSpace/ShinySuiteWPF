<Window x:Class="ShinySuite.Views.MiniPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="200"
        MinWidth="150"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeChanged="Window_SizeChanged">

    <Border Background="#EE1A1A1A"
            BorderBrush="#383838" BorderThickness="1"
            CornerRadius="10">
        <Border.LayoutTransform>
            <ScaleTransform ScaleX="{Binding Scale, RelativeSource={RelativeSource AncestorType=Window}}"
                            ScaleY="{Binding Scale, RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Border.LayoutTransform>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="3" Opacity="0.7" Direction="270"/>
        </Border.Effect>

        <Grid>

            <!-- Header (drag handle) -->
            <Grid Margin="8,7,8,5"
                  MouseLeftButtonDown="Header_MouseDown"
                  Cursor="SizeAll"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Name}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="#909090"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1"
                           Text="✕" FontSize="11"
                           Foreground="#505050"
                           Cursor="Arrow"
                           MouseLeftButtonDown="Close_Click">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#BBBBBB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Content -->
            <StackPanel Margin="8,28,8,8">

                <!-- Target Pokémon rows -->
                <ItemsControl ItemsSource="{Binding TargetTiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0"
                                       Source="{Binding Sprite}"
                                       Width="34" Height="34"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#E6B800"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Count, StringFormat='{}{0:N0}'}"
                                           FontSize="11"
                                           Foreground="#686868"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Divider -->
                <Rectangle Height="1" Fill="#2A2A2A" Margin="0,5,0,5"/>

                <!-- Stats grid: 3 cols × 2 rows (label + value) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Labels row 1 -->
                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Enc"   FontSize="9" Foreground="#585858" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="Enc/hr" FontSize="9" Foreground="#585858" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Phase" FontSize="9" Foreground="#585858" HorizontalAlignment="Center"/>

                    <!-- Values row 1 -->
                    <TextBlock Grid.Column="0" Grid.Row="1" Text="{Binding EncText}"  FontSize="12" FontWeight="SemiBold" Foreground="#C8C8C8" HorizontalAlignment="Center" Margin="0,1,0,5"/>
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding EphText}"  FontSize="12" FontWeight="SemiBold" Foreground="#C8C8C8" HorizontalAlignment="Center" Margin="0,1,0,5"/>
                    <TextBlock Grid.Column="2" Grid.Row="1" Text="{Binding Phases}"   FontSize="12" FontWeight="SemiBold" Foreground="#C8C8C8" HorizontalAlignment="Center" Margin="0,1,0,5"/>

                    <!-- Labels row 2 -->
                    <TextBlock Grid.Column="0" Grid.Row="2" Text="Time"  FontSize="9" Foreground="#585858" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Grid.Row="2" Text="Prob"  FontSize="9" Foreground="#585858" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Grid.Row="2" Text="Resets" FontSize="9" Foreground="#585858" HorizontalAlignment="Center"/>

                    <!-- Values row 2 -->
                    <TextBlock Grid.Column="0" Grid.Row="3" Text="{Binding TimeText}" FontSize="11" FontWeight="SemiBold" Foreground="#C8C8C8" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                    <TextBlock Grid.Column="1" Grid.Row="3" Text="{Binding ProbText}" FontSize="11" FontWeight="SemiBold" Foreground="#C8C8C8" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                    <TextBlock Grid.Column="2" Grid.Row="3" Text="{Binding Resets}"   FontSize="11" FontWeight="SemiBold" Foreground="#C8C8C8" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                </Grid>

                <!-- Pause / Resume -->
                <Button Command="{Binding ToggleRunningCommand}"
                        HorizontalAlignment="Stretch"
                        Margin="0,7,0,0"
                        Height="24" FontSize="10"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content"     Value="Resume"/>
                            <Setter Property="Background"  Value="#2A2A2A"/>
                            <Setter Property="Foreground"  Value="#909090"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#383838"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Content"    Value="Pause"/>
                                    <Setter Property="Foreground" Value="#E6B800"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

            <!-- Right-edge resize handle -->
            <Thumb HorizontalAlignment="Right" VerticalAlignment="Stretch"
                   Width="8" Cursor="SizeWE"
                   DragDelta="RightEdge_DragDelta">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

        </Grid>
    </Border>
</Window>
