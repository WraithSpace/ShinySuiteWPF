<Window x:Class="ShinySuite.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShinySuite" Width="380" Height="Auto" SizeToContent="Height"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">

    <StackPanel Margin="24,24,24,20">

        <!-- Title -->
        <TextBlock x:Name="TitleBlock"
                   FontSize="15" FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}"
                   Margin="0,0,0,12"
                   TextWrapping="Wrap"/>

        <!-- Message card -->
        <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                Padding="14,12" Margin="0,0,0,20">
            <TextBlock x:Name="MessageBlock"
                       Foreground="{StaticResource SubtleBrush}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       LineHeight="20"/>
        </Border>

        <!-- Don't ask again (optional) -->
        <CheckBox x:Name="DontAskBox"
                  Content="Don't ask again"
                  Foreground="{StaticResource SubtleBrush}"
                  FontSize="11"
                  Visibility="Collapsed"
                  Margin="0,0,0,14"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="No"
                    Style="{StaticResource DarkButton}"
                    Click="No_Click"
                    Margin="0,0,8,0"
                    MinWidth="72"/>
            <Button x:Name="YesButton"
                    Content="Yes"
                    Style="{StaticResource GoldButton}"
                    Click="Yes_Click"
                    MinWidth="72"/>
        </StackPanel>

    </StackPanel>
</Window>
