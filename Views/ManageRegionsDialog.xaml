<Window x:Class="ShinySuite.Views.ManageRegionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Capture Regions" Width="420" Height="400"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Active capture regions for this location:"
                   Foreground="{StaticResource SubtleBrush}"
                   FontSize="12" Margin="0,0,0,12"/>

        <!-- Regions list -->
        <Border Grid.Row="1" Background="{StaticResource HoverBrush}" CornerRadius="8">
            <ListBox x:Name="RegionsList"
                     Background="Transparent" BorderThickness="0"
                     Foreground="{StaticResource TextBrush}"
                     FontSize="13" Padding="4">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background"    Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"       Value="0"/>
                        <Setter Property="Margin"        Value="0,2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding}"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Style="{StaticResource IconButton}"
                                    Tag="{Binding}"
                                    Click="DeleteRegion_Click"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Add Region"
                    Style="{StaticResource DarkButton}"
                    Click="AddRegion_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Close"
                    Style="{StaticResource DarkButton}"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>

</Window>
