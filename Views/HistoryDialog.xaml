<Window x:Class="ShinySuite.Views.HistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shiny History" Width="700" Height="500"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Select All row -->
        <CheckBox x:Name="SelectAllBox" Grid.Row="0"
                  Content="Select All"
                  Foreground="{StaticResource TextBrush}"
                  Margin="4,0,0,8"
                  Checked="SelectAllBox_Changed"
                  Unchecked="SelectAllBox_Changed"/>

        <!-- History DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="HistoryGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="#1A1A1A"
                  RowBackground="#1E1E1E"
                  AlternatingRowBackground="#222222"
                  BorderThickness="0"
                  Foreground="{StaticResource TextBrush}"
                  FontSize="12"
                  ColumnHeaderHeight="34">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"   Value="{StaticResource HoverBrush}"/>
                    <Setter Property="Foreground"   Value="{StaticResource SubtleBrush}"/>
                    <Setter Property="Padding"      Value="10,0"/>
                    <Setter Property="FontSize"     Value="11"/>
                    <Setter Property="FontWeight"   Value="SemiBold"/>
                    <Setter Property="BorderBrush"  Value="#2A2A2A"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding"         Value="6,6"/>
                    <Setter Property="Foreground"      Value="{StaticResource TextBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="36" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Date"       Binding="{Binding Timestamp}" Width="130" IsReadOnly="True"/>
                <DataGridTextColumn Header="Pokémon"    Binding="{Binding Pokemon}"   Width="*"   IsReadOnly="True"/>
                <DataGridTextColumn Header="Location"   Binding="{Binding Route}"     Width="*"   IsReadOnly="True"/>
                <DataGridTextColumn Header="Encounters" Binding="{Binding Encounters}" Width="90"  IsReadOnly="True"/>
                <DataGridTextColumn Header="Resets"     Binding="{Binding Resets}"     Width="70"  IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="CountBlock"
                       DockPanel.Dock="Left"
                       Foreground="{StaticResource SubtleBrush}"
                       FontSize="12" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Delete Selected"
                        Style="{StaticResource DarkButton}"
                        Click="DeleteSelected_Click"
                        Margin="0,0,8,0"/>
                <Button Content="Delete All"
                        Style="{StaticResource DarkButton}"
                        Click="DeleteAll_Click"
                        Margin="0,0,8,0"/>
                <Button Content="Close"
                        Style="{StaticResource DarkButton}"
                        Click="Close_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>

</Window>
