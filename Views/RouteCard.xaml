<UserControl x:Class="ShinySuite.Views.RouteCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ShinySuite.ViewModels"
             xmlns:gif="http://wpfanimatedgif.codeplex.com">

    <Border Background="{StaticResource CardBrush}" CornerRadius="14"
            BorderThickness="1" BorderBrush="#282828"
            UseLayoutRounding="True"
            TextOptions.TextFormattingMode="Display"
            TextOptions.TextRenderingMode="ClearType">
        <StackPanel>

                <!-- ── Header ── -->
                <Grid Margin="12,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>

                    <!-- Expand toggle -->
                    <Button Grid.Column="0"
                            Content="{Binding ExpandIcon}"
                            Command="{Binding ToggleExpandCommand}"
                            Style="{StaticResource IconButton}"
                            VerticalAlignment="Center"/>

                    <!-- Name + stats -->
                    <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="16" FontWeight="SemiBold"
                                       />
                            <!-- Running indicator dot -->
                            <Ellipse Width="6" Height="6" Margin="7,0,0,0"
                                     VerticalAlignment="Center" IsHitTestVisible="False">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill"    Value="Transparent"/>
                                        <Setter Property="Opacity" Value="0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Fill"    Value="#44DD44"/>
                                                <Setter Property="Opacity" Value="1"/>
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#44DD44" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                        </StackPanel>
                        <TextBlock Text="{Binding StatsText}"
                                   Foreground="{StaticResource SubtleBrush}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Start / Stop — gold when running -->
                    <Button Grid.Column="2"
                            Content="{Binding StartLabel}"
                            Command="{Binding ToggleRunningCommand}"
                            FontSize="12" Padding="10,4"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DarkButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Background" Value="#3A2A00"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="14"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#5A4200"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Shiny Found -->
                    <Button Grid.Column="3"
                            Content="✨ Shiny Found!"
                            Command="{Binding ShinyFoundCommand}"
                            Style="{StaticResource GoldButton}"
                            FontSize="12" Padding="10,4"
                            Margin="0,0,8,0"/>

                    <!-- Pop Out -->
                    <Button Grid.Column="4"
                            Content="&#xE8A7;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14"
                            Width="32"
                            Command="{Binding PopOutCommand}"
                            Style="{StaticResource IconButton}"
                            VerticalAlignment="Center"
                            ToolTip="Pop out"/>

                    <!-- Remove -->
                    <Button Grid.Column="5"
                            Content="✕"
                            Command="{Binding RemoveCommand}"
                            Style="{StaticResource DangerIconButton}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- ── Expanded content ── -->
                <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolVis}}">

                    <!-- Spacing instead of separator line -->
                    <Border Height="8"/>

                    <!-- Category pills — PreviewMouseWheel redirected so outer list can scroll -->
                    <ScrollViewer x:Name="CategoryScroll"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Margin="10,0,10,8"
                                  PreviewMouseWheel="CategoryScroll_PreviewMouseWheel">
                        <ItemsControl ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:CategoryViewModel}">
                                    <ToggleButton Content="{Binding Name}"
                                                  IsChecked="{Binding IsActive, Mode=OneWay}"
                                                  Command="{Binding ActivateCommand}"
                                                  Style="{StaticResource PillButton}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Pokémon tiles for active category -->
                    <ItemsControl ItemsSource="{Binding ActiveCategory.Tiles}"
                                  Margin="8,0,8,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PokemonTileViewModel}">
                                <Border x:Name="TileBorder" CornerRadius="16" Width="148" Margin="4"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform><ScaleTransform/></Border.RenderTransform>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                        <GradientStop Color="#2E2E2E" Offset="0"/>
                                                        <GradientStop Color="#1E1E1E" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="BorderBrush"     Value="#383838"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                <GradientStop Color="#3A3A3A" Offset="0"/>
                                                                <GradientStop Color="#282828" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="BorderBrush"  Value="#505050"/>
                                                    <Setter Property="Panel.ZIndex" Value="10"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsTarget}" Value="True">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                <GradientStop Color="#24200C" Offset="0"/>
                                                                <GradientStop Color="#161308" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="BorderBrush"     Value="#C8A000"/>
                                                    <Setter Property="BorderThickness" Value="1.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <!-- Time-of-day / version badges (top-right, stacked) -->
                                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Orientation="Vertical" Margin="0,6,8,0">
                                            <Grid Width="26" Height="26"
                                                  Visibility="{Binding ShowTimeIcon, Converter={StaticResource BoolVis}}">
                                                <Grid.ToolTip>
                                                    <ToolTip Style="{StaticResource BubbleTip}">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Image Source="{Binding TimeIconImage}" Width="28" Height="28" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,10,0"/>
                                                            <TextBlock Text="{Binding TimeLabel}" Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Grid.ToolTip>
                                                <Border CornerRadius="13" Background="#28FFFFFF">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="Black" BlurRadius="4"
                                                                          ShadowDepth="2" Opacity="0.9" Direction="270"/>
                                                    </Border.Effect>
                                                </Border>
                                                <Image Source="{Binding TimeIconImage}" Width="20" Height="20"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>
                                            <!-- Grid layers shadow circle behind icon so effect doesn't blur the image -->
                                            <Grid Width="26" Height="26" Margin="0,2,0,0"
                                                  Visibility="{Binding Version2Visibility}">
                                                <Grid.ToolTip>
                                                    <ToolTip Style="{StaticResource BubbleTip}">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Image Source="{Binding Version2Icon}" Width="28" Height="28" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,10,0"/>
                                                            <TextBlock Text="{Binding Version2Label}" Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Grid.ToolTip>
                                                <Border CornerRadius="13" Background="#28FFFFFF">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="Black" BlurRadius="4"
                                                                          ShadowDepth="2" Opacity="0.9" Direction="270"/>
                                                    </Border.Effect>
                                                </Border>
                                                <Image Source="{Binding Version2Icon}" Width="20" Height="20"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>
                                            <Grid Width="26" Height="26" Margin="0,3,0,0"
                                                  Visibility="{Binding VersionVisibility}">
                                                <Grid.ToolTip>
                                                    <ToolTip Style="{StaticResource BubbleTip}">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Image Source="{Binding VersionIcon}" Width="28" Height="28" RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,10,0"/>
                                                            <TextBlock Text="{Binding VersionLabel}" Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Grid.ToolTip>
                                                <Border CornerRadius="13" Background="#28FFFFFF">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="Black" BlurRadius="4"
                                                                          ShadowDepth="2" Opacity="0.9" Direction="270"/>
                                                    </Border.Effect>
                                                </Border>
                                                <Image Source="{Binding VersionIcon}" Width="20" Height="20"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Shiny lock badge (top-left) -->
                                        <Grid Width="20" Height="20"
                                              HorizontalAlignment="Left" VerticalAlignment="Top"
                                              Margin="8,7,0,0"
                                              Visibility="{Binding ShinyLockVisibility}">
                                            <Grid.ToolTip>
                                                <ToolTip Style="{StaticResource BubbleTip}">
                                                    <TextBlock Text="Shiny Locked" Foreground="{StaticResource TextBrush}"
                                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </ToolTip>
                                            </Grid.ToolTip>
                                            <Border CornerRadius="10" Background="#40FF0000">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="Black" BlurRadius="4"
                                                                      ShadowDepth="2" Opacity="0.9" Direction="270"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="10" Foreground="#FF6666"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>

                                        <StackPanel Margin="10,12,10,12">
                                            <!-- Sprite (static PNG; shiny shown when IsTarget) -->
                                            <Image Source="{Binding Sprite}"
                                                   Width="80" Height="80"
                                                   HorizontalAlignment="Center"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                                            <!-- Display name -->
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontFamily="Segoe UI Symbol, pack://application:,,,/Fonts/InterVariable.ttf#Inter"
                                                       FontSize="11" TextAlignment="Center"
                                                       TextWrapping="Wrap" Margin="0,7,0,0"/>

                                            <!-- Counter — dark inset pill -->
                                            <Border Background="#161616" CornerRadius="16"
                                                    Margin="0,8,0,0" Padding="3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="26"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="26"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0"
                                                            Content="−"
                                                            Command="{Binding DecrementCommand}"
                                                            Style="{StaticResource CounterButton}"/>
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding Count, Mode=OneWay}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             HorizontalContentAlignment="Center"
                                                             Foreground="{StaticResource TextBrush}"
                                                             CaretBrush="{StaticResource TextBrush}"
                                                             FontSize="16" FontWeight="SemiBold"
                                                             MinWidth="32"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             GotFocus="CountBox_GotFocus"
                                                             LostFocus="CountBox_LostFocus"
                                                             PreviewKeyDown="CountBox_PreviewKeyDown"/>
                                                    <Button Grid.Column="2"
                                                            Content="+"
                                                            Command="{Binding IncrementCommand}"
                                                            Style="{StaticResource CounterButton}"/>
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                                        <!-- Sparkle burst — fires once when IsTarget=True -->
                                        <Canvas x:Name="SparkleCanvas" Width="150" Height="100"
                                                VerticalAlignment="Top" IsHitTestVisible="False"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Canvas.RenderTransform><RotateTransform/></Canvas.RenderTransform>
                                            <!-- Main burst stars (large, 8 cardinal+diagonal directions) -->
                                            <TextBlock x:Name="Sp1" Text="✦" FontSize="13" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Sp2" Text="✦" FontSize="13" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Sp3" Text="✦" FontSize="13" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Sp4" Text="✦" FontSize="13" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Sp5" Text="✦" FontSize="13" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Sp6" Text="✦" FontSize="13" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Sp7" Text="✦" FontSize="13" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Sp8" Text="✦" FontSize="13" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <!-- Trailing stars (small, between main directions, slight delay) -->
                                            <TextBlock x:Name="Tr1" Text="✦" FontSize="6" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Tr2" Text="✦" FontSize="6" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Tr3" Text="✦" FontSize="6" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Tr4" Text="✦" FontSize="6" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Tr5" Text="✦" FontSize="6" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Tr6" Text="✦" FontSize="6" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Tr7" Text="✦" FontSize="6" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                            <TextBlock x:Name="Tr8" Text="✦" FontSize="6" Foreground="#ADD8E6" Canvas.Left="70" Canvas.Top="44" Opacity="0"><TextBlock.RenderTransform><TranslateTransform/></TextBlock.RenderTransform></TextBlock>
                                        </Canvas>
                                        <!-- Glitter stars — condensed blinks near sprite center (~75,50), varied sizes -->
                                        <Canvas x:Name="GlitterCanvas" Width="150" Height="165"
                                                VerticalAlignment="Top" IsHitTestVisible="False">
                                            <TextBlock x:Name="G1" Text="✦" FontSize="10" Foreground="#ADD8E6" Canvas.Left="44"  Canvas.Top="28"  Opacity="0"/>
                                            <TextBlock x:Name="G2" Text="✦" FontSize="6"  Foreground="#ADD8E6" Canvas.Left="98"  Canvas.Top="25"  Opacity="0"/>
                                            <TextBlock x:Name="G3" Text="✦" FontSize="8"  Foreground="#ADD8E6" Canvas.Left="106" Canvas.Top="52"  Opacity="0"/>
                                            <TextBlock x:Name="G4" Text="✦" FontSize="5"  Foreground="#ADD8E6" Canvas.Left="84"  Canvas.Top="74"  Opacity="0"/>
                                            <TextBlock x:Name="G5" Text="✦" FontSize="7"  Foreground="#ADD8E6" Canvas.Left="48"  Canvas.Top="70"  Opacity="0"/>
                                            <TextBlock x:Name="G6" Text="✦" FontSize="9"  Foreground="#ADD8E6" Canvas.Left="38"  Canvas.Top="46"  Opacity="0"/>
                                            <TextBlock x:Name="G7" Text="✦" FontSize="6"  Foreground="#ADD8E6" Canvas.Left="72"  Canvas.Top="18"  Opacity="0"/>
                                            <TextBlock x:Name="G8" Text="✦" FontSize="8"  Foreground="#ADD8E6" Canvas.Left="62"  Canvas.Top="80"  Opacity="0"/>
                                        </Canvas>

                                    </Grid>
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Set as Target"
                                                      Command="{Binding SetTargetCommand}"/>
                                            <MenuItem Header="Clear Target"
                                                      Command="{Binding RemoveTargetCommand}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                </Border>
                                <DataTemplate.Triggers>
                                    <EventTrigger RoutedEvent="UIElement.MouseEnter" SourceName="TileBorder">
                                        <BeginStoryboard x:Name="TileHoverIn">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="TileBorder"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                    To="1.05" Duration="0:0:0.12">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="TileBorder"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                    To="1.05" Duration="0:0:0.12">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="UIElement.MouseLeave" SourceName="TileBorder">
                                        <BeginStoryboard x:Name="TileHoverOut">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="TileBorder"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                    To="1.0" Duration="0:0:0.18">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="TileBorder"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                    To="1.0" Duration="0:0:0.18">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <DataTrigger Binding="{Binding IsTarget}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="SparkleBoard">
                                                <Storyboard>
                                                    <!-- Canvas spins 90° clockwise -->
                                                    <DoubleAnimation Storyboard.TargetName="SparkleCanvas" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="90" Duration="0:0:0.5"/>
                                                    <!-- Main burst opacity 0→1→0 -->
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Sp1" Storyboard.TargetProperty="Opacity"><LinearDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/><LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="1"/><LinearDoubleKeyFrame KeyTime="0:0:0.50" Value="0"/></DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Sp2" Storyboard.TargetProperty="Opacity"><LinearDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/><LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="1"/><LinearDoubleKeyFrame KeyTime="0:0:0.50" Value="0"/></DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Sp3" Storyboard.TargetProperty="Opacity"><LinearDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/><LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="1"/><LinearDoubleKeyFrame KeyTime="0:0:0.50" Value="0"/></DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Sp4" Storyboard.TargetProperty="Opacity"><LinearDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/><LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="1"/><LinearDoubleKeyFrame KeyTime="0:0:0.50" Value="0"/></DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Sp5" Storyboard.TargetProperty="Opacity"><LinearDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/><LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="1"/><LinearDoubleKeyFrame KeyTime="0:0:0.50" Value="0"/></DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Sp6" Storyboard.TargetProperty="Opacity"><LinearDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/><LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="1"/><LinearDoubleKeyFrame KeyTime="0:0:0.50" Value="0"/></DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Sp7" Storyboard.TargetProperty="Opacity"><LinearDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/><LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="1"/><LinearDoubleKeyFrame KeyTime="0:0:0.50" Value="0"/></DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Sp8" Storyboard.TargetProperty="Opacity"><LinearDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/><LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="1"/><LinearDoubleKeyFrame KeyTime="0:0:0.50" Value="0"/></DoubleAnimationUsingKeyFrames>
                                                    <!-- Main translate -->
                                                    <DoubleAnimation Storyboard.TargetName="Sp1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="0" To="0"   Duration="0:0:0.5"/>
                                                    <DoubleAnimation Storyboard.TargetName="Sp1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="0" To="-32" Duration="0:0:0.5"/>
                                                    <DoubleAnimation Storyboard.TargetName="Sp2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="0" To="23"  Duration="0:0:0.5"/>
                                                    <DoubleAnimation Storyboard.TargetName="Sp2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="0" To="-23" Duration="0:0:0.5"/>
                                                    <DoubleAnimation Storyboard.TargetName="Sp3" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="0" To="32"  Duration="0:0:0.5"/>
                                                    <DoubleAnimation Storyboard.TargetName="Sp3" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="0" To="0"   Duration="0:0:0.5"/>
