<Window x:Class="ShinySuite.Views.ManageLocationsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Locations" Width="420" SizeToContent="Height" MaxHeight="560"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <StackPanel Margin="20,20,20,16">

        <!-- Title -->
        <TextBlock Text="Manage Locations"
                   FontSize="15" FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}"
                   Margin="0,0,0,14"/>

        <!-- Select All row -->
        <CheckBox x:Name="SelectAllBox"
                  Content="Select All"
                  Foreground="{StaticResource SubtleBrush}"
                  FontSize="12"
                  Margin="2,0,0,8"
                  Checked="SelectAllBox_Changed"
                  Unchecked="SelectAllBox_Changed"/>

        <!-- Route list -->
        <Border Background="#161616" CornerRadius="8" Padding="4" MaxHeight="340">
            <ListBox x:Name="RouteList"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background"       Value="Transparent"/>
                        <Setter Property="BorderThickness"  Value="0"/>
                        <Setter Property="Padding"          Value="10,7"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected}"
                                  Content="{Binding Name}"
                                  FontSize="13"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Separator -->
        <Rectangle Height="1" Fill="#242424" Margin="0,14,0,10"/>

        <!-- Warning -->
        <TextBlock Text="Deleted locations lose all data permanently."
                   Foreground="#CC4444" FontSize="11"
                   Margin="0,0,0,12"/>

        <!-- Footer row: reset link left, action buttons right -->
        <DockPanel>
            <Button x:Name="ResetPromptsBtn"
                    DockPanel.Dock="Left"
                    Content="Restore confirmation prompts"
                    Style="{StaticResource DarkButton}"
                    FontSize="11"
                    Visibility="Collapsed"
                    Click="ResetPrompts_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Delete Selected"
                        Style="{StaticResource DangerButton}"
                        Click="DeleteSelected_Click"
                        Margin="0,0,8,0"/>
                <Button Content="Close"
                        Style="{StaticResource DarkButton}"
                        Click="Close_Click"/>
            </StackPanel>
        </DockPanel>

    </StackPanel>
</Window>
