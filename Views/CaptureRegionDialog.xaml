<Window x:Class="ShinySuite.Views.CaptureRegionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Capture Region" Width="420" Height="340"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">

    <StackPanel Margin="20">

        <TextBlock Text="Drag on-screen to capture coordinates, or enter them manually below."
                   Foreground="{StaticResource SubtleBrush}"
                   TextWrapping="Wrap" FontSize="12"
                   Margin="0,0,0,8"/>

        <Button Content="Select Region on Screen"
                Style="{StaticResource DarkButton}"
                HorizontalAlignment="Left"
                Click="SelectRegion_Click"
                Margin="0,0,0,16"/>

        <!-- Coordinate inputs -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Grid.Row="0" Text="X" Foreground="{StaticResource SubtleBrush}" FontSize="12" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Grid.Row="0" Text="Y" Foreground="{StaticResource SubtleBrush}" FontSize="12" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="4" Grid.Row="0" Text="Width" Foreground="{StaticResource SubtleBrush}" FontSize="12" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="6" Grid.Row="0" Text="Height" Foreground="{StaticResource SubtleBrush}" FontSize="12" HorizontalAlignment="Center"/>

            <TextBox x:Name="TbX" Grid.Column="0" Grid.Row="2" Text="0"  Height="34" Padding="8,0" Style="{StaticResource SearchBox}" Background="{StaticResource HoverBrush}" TextAlignment="Center"/>
            <TextBox x:Name="TbY" Grid.Column="2" Grid.Row="2" Text="0"  Height="34" Padding="8,0" Style="{StaticResource SearchBox}" Background="{StaticResource HoverBrush}" TextAlignment="Center"/>
            <TextBox x:Name="TbW" Grid.Column="4" Grid.Row="2" Text="200" Height="34" Padding="8,0" Style="{StaticResource SearchBox}" Background="{StaticResource HoverBrush}" TextAlignment="Center"/>
            <TextBox x:Name="TbH" Grid.Column="6" Grid.Row="2" Text="40"  Height="34" Padding="8,0" Style="{StaticResource SearchBox}" Background="{StaticResource HoverBrush}" TextAlignment="Center"/>
        </Grid>

        <!-- Preview area -->
        <TextBlock Text="Preview" Foreground="{StaticResource SubtleBrush}" FontSize="11" Margin="0,0,0,4"/>
        <Border Background="{StaticResource HoverBrush}" Height="90" CornerRadius="6"
                Margin="0,0,0,16">
            <Image x:Name="PreviewImage" Stretch="Uniform"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Test Capture"
                    Style="{StaticResource DarkButton}"
                    Click="TestCapture_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Cancel"
                    Style="{StaticResource DarkButton}"
                    Click="Cancel_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Add Region"
                    Style="{StaticResource GoldButton}"
                    Click="Add_Click"/>
        </StackPanel>
    </StackPanel>

</Window>
