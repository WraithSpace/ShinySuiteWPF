<Window x:Class="ShinySuite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ShinySuite.ViewModels"
        xmlns:views="clr-namespace:ShinySuite.Views"
        Title="ShinySuite" Height="860" Width="1280" MinWidth="700" MinHeight="300"
        Icon="pack://application:,,,/app.ico"
        Background="Transparent"
        WindowStyle="None"
        FontFamily="pack://application:,,,/Fonts/InterVariable.ttf#Inter"
        WindowStartupLocation="CenterScreen"
        PreviewMouseDown="Window_PreviewMouseDown">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      ResizeBorderThickness="6"
                      CaptionHeight="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource BgBrush}" CornerRadius="8" ClipToBounds="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarCol" Width="200" MinWidth="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <!-- ── Title bar ── -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="Black"
                BorderThickness="0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <DockPanel>

                <!-- Window controls (right) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource WinBtn}"
                            Content="&#xE921;"
                            Click="Minimize_Click"/>
                    <Button x:Name="MaximizeBtn"
                            Style="{StaticResource WinBtn}"
                            Content="&#xE922;"
                            Click="MaximizeRestore_Click"/>
                    <Button Style="{StaticResource WinBtnClose}"
                            Content="&#xE8BB;"
                            Click="Close_Click"/>
                </StackPanel>

                <!-- Sidebar toggle + logo (left) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="SidebarToggle"
                            Margin="8,0,0,0"
                            Style="{StaticResource IconButton}"
                            FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Content="&#xE76B;"
                            Click="SidebarToggle_Click"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                        <Border Background="{StaticResource AccentColor}"
                                CornerRadius="8" Width="28" Height="28">
                            <TextBlock Text="S" FontWeight="Bold" FontSize="13"
                                       Foreground="#111111"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ShinySuite"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ── Sidebar ── -->
        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource CardBrush}"
                BorderThickness="0"
                ClipToBounds="True">
            <DockPanel>

                <!-- Stats at bottom -->
                <Border x:Name="StatsBorder" DockPanel.Dock="Bottom"
                        Padding="14,10" BorderThickness="0">
                    <TextBlock Text="{Binding GlobalStats}"
                               Foreground="{StaticResource SubtleBrush}" FontSize="11"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Nav items (fills remaining space) -->
                <StackPanel Margin="8,10,8,0">

                    <!-- Search -->
                    <Border x:Name="SearchBorder" Margin="0,0,0,10"
                            Background="{StaticResource HoverBrush}"
                            CornerRadius="8" Height="34">
                        <DockPanel VerticalAlignment="Center">
                            <Button DockPanel.Dock="Left" Style="{StaticResource IconButton}"
                                    Width="30" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                    Content="&#xE721;"
                                    Click="SearchIcon_Click" ToolTip="Search"/>
                            <Button x:Name="SearchAddBtn" DockPanel.Dock="Right" Content="+"
                                    FontSize="16" Style="{StaticResource IconButton}"
                                    Width="28" Height="28"
                                    Click="AddButton_Click" ToolTip="Add location"/>
                            <Grid x:Name="SearchInputArea">
                                <TextBox x:Name="SearchBox"
                                         Style="{StaticResource SearchBox}"
                                         Height="28"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         GotFocus="SearchBox_GotFocus"
                                         LostFocus="SearchBox_LostFocus"
                                         PreviewKeyDown="SearchBox_PreviewKeyDown"/>
                                <TextBlock Text="Search..."
                                           Foreground="#555555" FontSize="12"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <!-- Game selector -->
                    <Border x:Name="GameSelectorWrap" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="GAME" FontSize="10"
                                       Foreground="{StaticResource SubtleBrush}"
                                       Margin="4,0,0,4" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding GameList}"
                                      SelectedItem="{Binding SelectedGame}"/>
                        </StackPanel>
                    </Border>

                    <!-- Scale selector -->
                    <Border x:Name="ScaleSelectorWrap" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="UI SCALE" FontSize="10"
                                       Foreground="{StaticResource SubtleBrush}"
                                       Margin="4,0,0,4" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding ScaleOptions}"
                                      SelectedItem="{Binding SelectedScale}"/>
                        </StackPanel>
                    </Border>

                    <!-- Divider -->
                    <Border Height="1" Background="#242424" Margin="4,0,4,12"/>

                    <!-- Locations -->
                    <Button x:Name="LocationsBtn" Style="{StaticResource NavButton}"
                            Margin="0,0,0,2"
                            Command="{Binding ManageLocationsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE707;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" VerticalAlignment="Center"
                                       Width="22" TextAlignment="Center"/>
                            <TextBlock x:Name="LocationsLabel" Text="Locations"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- OCR -->
                    <Button x:Name="OcrBtn" Style="{StaticResource NavButton}"
                            Margin="0,0,0,2"
                            Command="{Binding ManageCapturesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" VerticalAlignment="Center"
                                       Width="22" TextAlignment="Center"/>
                            <TextBlock x:Name="OcrLabel" Text="OCR Regions"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- History -->
                    <Button x:Name="HistoryBtn" Style="{StaticResource NavButton}"
                            Margin="0,0,0,2"
                            Command="{Binding ShowHistoryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="15" VerticalAlignment="Center"
                                       Width="22" TextAlignment="Center"/>
                            <TextBlock x:Name="HistoryLabel" Text="History"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Main content ── -->
        <Grid Grid.Row="1" Grid.Column="1">

            <!-- Routes list (virtualized) -->
            <Grid>
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}"/>
                </Grid.LayoutTransform>

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            IsHitTestVisible="False" Panel.ZIndex="0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Routes.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="No locations tracked yet"
                               FontSize="15" Foreground="#3C3C3C"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Use the search bar on the left to add a route"
                               FontSize="12" Foreground="#2E2E2E"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <ListBox x:Name="RoutesList"
                         ItemsSource="{Binding Routes}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel"
                         Padding="12,8,12,12"
                         FocusVisualStyle="{x:Null}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background"                 Value="Transparent"/>
                            <Setter Property="BorderThickness"            Value="0"/>
                            <Setter Property="Padding"                    Value="0"/>
                            <Setter Property="Margin"                     Value="0,0,0,8"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:RouteViewModel}">
                            <views:RouteCard/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- ── Suggestions dropdown ── -->
        <Border x:Name="SuggestionsDropdown"
                Grid.RowSpan="2" Grid.ColumnSpan="2"
                Panel.ZIndex="100"
                Visibility="Collapsed"
                VerticalAlignment="Top" HorizontalAlignment="Left"
                Background="#252525"
                BorderBrush="#3A3A3A" BorderThickness="1"
                CornerRadius="8">
            <ListBox x:Name="SuggestionsList"
                     Style="{StaticResource DropdownList}"
                     MaxHeight="320"
                     ItemsSource="{Binding Filtered}"
                     PreviewMouseLeftButtonDown="SuggestionsList_PreviewMouseLeftButtonDown"/>
        </Border>
    </Grid>
    </Border>
</Window>
